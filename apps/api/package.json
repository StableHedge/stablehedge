{
  "name": "@stablehedge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "scripts:setup-issuer": "tsx ../../scripts/setup-issuer.ts",
    "scripts:open-trustlines": "tsx ../../scripts/open-investor-trustlines.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/client": "^5.22.0",
    "@stablehedge/shared-types": "workspace:*",
    "@stablehedge/xrpl-adapter": "workspace:*",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "pino-pretty": "^11.2.2",
    "xrpl": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4"
  }
}
